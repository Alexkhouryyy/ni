ANTHROPIC_API_KEY=your_key_here

# OpenAI — required for GPT models, optional for OpenAI voice (TTS/STT)
OPENAI_API_KEY=your_openai_key_here
# AGENT_MODEL=gpt-4o         # Override starting model (default: claude-opus-4-7)
# TTS_ENGINE=openai          # pyttsx3 | elevenlabs | openai
# OPENAI_TTS_VOICE=alloy     # alloy | echo | fable | onyx | nova | shimmer
# OPENAI_STT_ENGINE=openai   # local (faster-whisper) | openai (Whisper API)

# Google Gemini — required for Gemini models and the 3-way /council debate
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

ELEVENLABS_API_KEY=optional_for_better_voice
ELEVENLABS_VOICE_ID=optional_voice_id

# === Tier-4 ===

# Phone (Twilio) — get from https://console.twilio.com
# Inbound webhooks point at https://your-ngrok-url/twilio/sms and /twilio/voice
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Comma-separated allowlist of numbers that may dispatch the agent inbound.
# Leave blank to allow any (NOT recommended in production).
PHONE_ALLOWED_NUMBERS=

# Telegram bot — create one with @BotFather, get your chat ID from @userinfobot.
TELEGRAM_BOT_TOKEN=
# Comma-separated chat-ID allowlist. Apex can run bash — leaving this blank lets
# anyone who finds the bot control it. Strongly recommended to set your own ID.
TELEGRAM_ALLOWED_CHAT_IDS=
# Long-polling: Apex pulls messages via getUpdates, so no public URL / webhook
# is needed (ideal for a laptop or home machine). Set false to use a webhook
# at https://your-host/telegram/webhook instead.
TELEGRAM_POLLING=false

# Image generation (Replicate) — get from https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
IMAGE_GEN_MODEL=black-forest-labs/flux-schnell
IMAGE_GEN_OUTPUT_DIR=~/.voice_agent_images

# Discord bot — create an app at https://discord.com/developers/applications
# Set the Interactions Endpoint URL to https://your-host/discord/interactions
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_DEFAULT_CHANNEL_ID=
# Comma-separated allowlist of Discord user IDs permitted to invoke the agent.
# Leave blank to allow any (NOT recommended in production).
DISCORD_ALLOWED_USER_IDS=

# Slack bot — create an app at https://api.slack.com/apps
# Enable Event Subscriptions → set Request URL to https://your-host/slack/events
# Subscribe to bot events: app_mention and/or message.channels
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# Comma-separated allowlist of Slack channel IDs. Leave blank to allow all.
SLACK_ALLOWED_CHANNEL_IDS=

# WhatsApp via Twilio — reuses TWILIO_SID / TWILIO_AUTH_TOKEN above.
# Enable WhatsApp in Twilio console or use the sandbox.
# Set the WhatsApp webhook URL to https://your-host/twilio/whatsapp
WHATSAPP_FROM_NUMBER=whatsapp:+14155238886
# Comma-separated E.164 allowlist. Leave blank to allow any (NOT recommended).
WHATSAPP_ALLOWED_NUMBERS=

# Signal via signal-cli-rest-api (https://github.com/bbernhard/signal-cli-rest-api)
# docker run -d -p 8080:8080 -e MODE=json-rpc bbernhard/signal-cli-rest-api
# Register your number at http://localhost:8080/v1/qrcodelink
# Set webhook URL to https://your-host/signal/webhook
SIGNAL_CLI_URL=http://localhost:8080
SIGNAL_PHONE_NUMBER=
# Comma-separated E.164 allowlist. Leave blank to allow any (NOT recommended).
SIGNAL_ALLOWED_NUMBERS=

# Ollama local models — run models entirely offline, no API key required.
# Install Ollama: https://ollama.com  →  then: ollama pull llama3.2
# Any model you pull is available with the ollama/ prefix (e.g. /model ollama/llama3.2)
# Default points at a local Ollama instance; change for a remote one.
OLLAMA_BASE_URL=http://localhost:11434/v1
# To add a local model to the council debate, set this (e.g. ollama/llama3.1):
OLLAMA_COUNCIL_MODEL=

# Cloud deployment (Railway / Render / any host)
# Set DASHBOARD_TOKEN to any strong password — empty = open (local dev)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_TOKEN=your_secret_token_here
DB_PATH=/data/apex.db

# === Omnipresence — cross-device presence (PWA + Web Push) ===
# Public HTTPS origin once you expose Apex via a tunnel (Cloudflare/Tailscale).
# Used for push click-through URLs, the PWA, and QR pairing. Empty = LAN/local.
PUBLIC_BASE_URL=
# Web Push (VAPID). Generate once:  python scripts/gen_vapid_keys.py >> .env
# The private key is a secret — it stays in .env (git-ignored), never commit it.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# Fall back to Telegram for proactive nudges until a device subscribes to push.
NOTIFY_TELEGRAM_FALLBACK=true
NOTIFY_DEDUP_SECONDS=30

# Webcam — single-frame capture from your local camera for Claude vision.
# Off by default (opt-in). Requires: pip install opencv-python
CAMERA_ENABLED=false
CAMERA_DEVICE_INDEX=0

# === Guardian Angel — decision-moment detection ===
# Watches for high-stakes commitment moments (angry email, late-night purchase,
# destructive commit, credential paste) and intervenes with one spoken line.
# Toggle on/off at runtime from the Telemetry tab in the dashboard.
GUARDIAN_ANGEL_ENABLED=true
GUARDIAN_THRESHOLD=0.70          # confidence threshold to fire (0–1)
GUARDIAN_COOLDOWN_MINUTES=20     # min gap between same-type interventions
GUARDIAN_MODELS=claude-haiku-4-5-20251001,gpt-4o-mini

# === Time Capsule — long-horizon memory with a heartbeat ===
# Bookmarks goal/emotional statements you make ("I want to start running") and
# surfaces them again, unprompted, days or weeks later ("how's that going?").
# A cheap regex pre-filter gates a single Haiku call, so cost stays near zero.
# Toggle on/off at runtime from the Telemetry tab in the dashboard.
TIME_CAPSULE_ENABLED=true
TIME_CAPSULE_MODEL=claude-haiku-4-5-20251001
TIME_CAPSULE_SCAN_INTERVAL_SECONDS=60        # how often to scan new turns for goals
TIME_CAPSULE_SURFACE_INTERVAL_SECONDS=1800   # how often to surface a due callback
TIME_CAPSULE_DEFAULT_CALLBACK_DAYS=14        # fallback horizon when none is implied
TIME_CAPSULE_MAX_PER_DAY=2                    # cap on callbacks delivered per day

# Resident mode — always-on background companion (python main.py --resident)
# Wake word is "Apex". Silent boot (no greeting on launch). Logs to ~/.apex/.
WAKE_WORD_ENABLED=true
RESIDENT_SILENT_BOOT=true
RESIDENT_LOG_FILE=~/.apex/resident.log
RESIDENT_AUDIT_FILE=~/.apex/wake_audit.log
# Global hotkey to wake Apex without speaking (handy in meetings).
# Format: pynput combo syntax — examples: <ctrl>+<space>, <ctrl>+<alt>+a
RESIDENT_GLOBAL_HOTKEY=<ctrl>+<space>
# Global hotkey to toggle mute (mic discarded entirely when muted).
RESIDENT_MUTE_HOTKEY=<ctrl>+<alt>+m

# IoT — Home Assistant integration (off by default)
# Set IOT_ENABLED=true to activate all three IoT layers (control, triggers, awareness).
# You can also toggle at runtime via the dashboard or: /iot on | /iot off
IOT_ENABLED=false
# Your Home Assistant base URL. LAN: http://homeassistant.local:8123
# Cloud: https://<your-id>.ui.nabu.casa  or via Tailscale subnet.
IOT_HA_URL=http://homeassistant.local:8123
# Long-lived access token from HA → Profile → Long-Lived Access Tokens
IOT_HA_TOKEN=
# HMAC-SHA256 secret for inbound webhook signature verification.
# Set the same value in your HA automation as the X-Apex-Signature header.
IOT_WEBHOOK_SECRET=
# Comma-separated entity_id allowlist for the passive awareness watcher.
# Example: binary_sensor.front_door,sensor.kitchen_temperature
# Leave blank to disable passive awareness (recommended until you know what you want).
IOT_AWARENESS_ENTITIES=
# Comma-separated entity_id allowlist for inbound trigger webhooks.
# Example: binary_sensor.driveway_motion,binary_sensor.front_door
# Leave blank to block all inbound triggers.
IOT_TRIGGER_ALLOWED_ENTITIES=

# === Safety: spend caps ===
# Daily and per-session USD limits. Set to 0 to disable a cap individually.
# Apex will refuse to process more requests once a cap is reached and explain why.
# Live values are stored in SQLite and editable from the dashboard without restart —
# these .env keys only seed the DB on first boot.
DAILY_SPEND_LIMIT_USD=5.00
SESSION_SPEND_LIMIT_USD=2.00
