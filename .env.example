ANTHROPIC_API_KEY=your_key_here

# OpenAI — required for GPT models, optional for OpenAI voice (TTS/STT)
OPENAI_API_KEY=your_openai_key_here
# AGENT_MODEL=gpt-4o         # Override starting model (default: claude-opus-4-7)
# TTS_ENGINE=openai          # pyttsx3 | elevenlabs | openai
# OPENAI_TTS_VOICE=alloy     # alloy | echo | fable | onyx | nova | shimmer
# OPENAI_STT_ENGINE=openai   # local (faster-whisper) | openai (Whisper API)

ELEVENLABS_API_KEY=optional_for_better_voice
ELEVENLABS_VOICE_ID=optional_voice_id

# === Tier-4 ===

# Phone (Twilio) — get from https://console.twilio.com
# Inbound webhooks point at https://your-ngrok-url/twilio/sms and /twilio/voice
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Comma-separated allowlist of numbers that may dispatch the agent inbound.
# Leave blank to allow any (NOT recommended in production).
PHONE_ALLOWED_NUMBERS=

# Image generation (Replicate) — get from https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
IMAGE_GEN_MODEL=black-forest-labs/flux-schnell
IMAGE_GEN_OUTPUT_DIR=~/.voice_agent_images

# Discord bot — create an app at https://discord.com/developers/applications
# Set the Interactions Endpoint URL to https://your-host/discord/interactions
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_DEFAULT_CHANNEL_ID=
# Comma-separated allowlist of Discord user IDs permitted to invoke the agent.
# Leave blank to allow any (NOT recommended in production).
DISCORD_ALLOWED_USER_IDS=

# Cloud deployment (Railway / Render / any host)
# Set DASHBOARD_TOKEN to any strong password — empty = open (local dev)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_TOKEN=your_secret_token_here
DB_PATH=/data/apex.db
