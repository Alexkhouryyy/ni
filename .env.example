# Required API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Optional: OpenAI TTS voice (onyx is deep/authoritative, closest to JARVIS)
# Options: onyx, echo, fable, alloy, nova, shimmer
# OPENAI_TTS_VOICE=onyx

# Optional: OpenAI TTS model (tts-1 is faster, tts-1-hd is higher quality)
# OPENAI_TTS_MODEL=tts-1

# Optional: Your name (JARVIS will address you by name)
# USER_NAME=Tony

# Optional: Specific calendar accounts to read (comma-separated emails)
# If not set, reads ALL calendars
# CALENDAR_ACCOUNTS=you@gmail.com,work@company.com

# ── Food Ordering & Reservations ───────────────────────────────────────────

# Region for food ordering: auto | me (Middle East/Toters) | us (DoorDash/UberEats — v2 stub)
JARVIS_REGION=me

# Your phone number for WhatsApp reservation drafts (include country code, e.g. +9611234567)
USER_PHONE=

# Maximum order value before JARVIS asks for a second confirmation (in local currency)
ORDER_MAX_VALUE=50

# Enable/disable Toters provider (default: true)
TOTERS_ENABLED=true

# ── Screen Vision Hotkey ───────────────────────────────────────────────────
# Global OS-level hotkey: press anywhere to have JARVIS analyze your screen
# (screenshot → Claude Haiku vision → spoken response). Hotkey press = permission.
# Syntax uses pynput keycodes: e.g. <ctrl>+<shift>+j, <cmd>+<alt>+j
SCREEN_HOTKEY_ENABLED=true
SCREEN_HOTKEY=<ctrl>+<shift>+j

# ── Proactive Interruptions ────────────────────────────────────────────────
# When enabled, JARVIS speaks up about meetings (10 min and 2 min before),
# overdue tasks, and weather shifts — without being asked. Toggle off in
# Settings during deep focus or meetings; takes effect within 60 seconds.
PROACTIVE_ENABLED=true

# ── LLM Routing ────────────────────────────────────────────────────────────
# JARVIS routes calls through a model selector. Set these to switch between
# Anthropic (claude-*) and local Ollama (ollama:<model>) per tier.
#
# MODEL_FAST = cheap-tier: classification, summaries, intent, screen describe
# MODEL_SMART = main chat / reasoning tier
#
# Examples:
#   MODEL_FAST=claude-haiku-4-5            (default; paid)
#   MODEL_FAST=ollama:llama3.1:8b          (free; recommended on a 4070+)
#   MODEL_FAST=ollama:deepseek-r1:14b      (free; smarter but slower)
MODEL_FAST=claude-haiku-4-5
MODEL_SMART=claude-opus-4-6
OLLAMA_URL=http://localhost:11434

# ── Compounding Memory ─────────────────────────────────────────────────────
# JARVIS extracts stable facts about you in the background every N seconds
# (default 600 = 10 min). Stored in data/jarvis.db + ~/.jarvis/me.md.
# Toggle off in Settings during sensitive conversations.
MEMORY_DISTILL_ENABLED=true
MEMORY_DISTILL_INTERVAL=600

# ── Desktop Shell (Floating Orb) ───────────────────────────────────────────
# Hotkey to toggle the floating-orb window visibility (when running
# desktop_shell.py). Same syntax as SCREEN_HOTKEY (pynput combo).
DESKTOP_SHELL_HOTKEY=<ctrl>+<shift>+\
# Override the frontend URL the orb loads (default: http://localhost:5195)
# DESKTOP_SHELL_FRONTEND_URL=http://localhost:5195
