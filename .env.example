ANTHROPIC_API_KEY=your_key_here

# OpenAI — required for GPT models, optional for OpenAI voice (TTS/STT)
OPENAI_API_KEY=your_openai_key_here
# AGENT_MODEL=gpt-4o         # Override starting model (default: claude-opus-4-7)
# TTS_ENGINE=openai          # pyttsx3 | elevenlabs | openai
# OPENAI_TTS_VOICE=alloy     # alloy | echo | fable | onyx | nova | shimmer
# OPENAI_STT_ENGINE=openai   # local (faster-whisper) | openai (Whisper API)

# Google Gemini — required for Gemini models and the 3-way /council debate
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

ELEVENLABS_API_KEY=optional_for_better_voice
ELEVENLABS_VOICE_ID=optional_voice_id

# === Tier-4 ===

# Phone (Twilio) — get from https://console.twilio.com
# Inbound webhooks point at https://your-ngrok-url/twilio/sms and /twilio/voice
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Comma-separated allowlist of numbers that may dispatch the agent inbound.
# Leave blank to allow any (NOT recommended in production).
PHONE_ALLOWED_NUMBERS=

# Image generation (Replicate) — get from https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
IMAGE_GEN_MODEL=black-forest-labs/flux-schnell
IMAGE_GEN_OUTPUT_DIR=~/.voice_agent_images

# Discord bot — create an app at https://discord.com/developers/applications
# Set the Interactions Endpoint URL to https://your-host/discord/interactions
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=
DISCORD_DEFAULT_CHANNEL_ID=
# Comma-separated allowlist of Discord user IDs permitted to invoke the agent.
# Leave blank to allow any (NOT recommended in production).
DISCORD_ALLOWED_USER_IDS=

# Slack bot — create an app at https://api.slack.com/apps
# Enable Event Subscriptions → set Request URL to https://your-host/slack/events
# Subscribe to bot events: app_mention and/or message.channels
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
# Comma-separated allowlist of Slack channel IDs. Leave blank to allow all.
SLACK_ALLOWED_CHANNEL_IDS=

# WhatsApp via Twilio — reuses TWILIO_SID / TWILIO_AUTH_TOKEN above.
# Enable WhatsApp in Twilio console or use the sandbox.
# Set the WhatsApp webhook URL to https://your-host/twilio/whatsapp
WHATSAPP_FROM_NUMBER=whatsapp:+14155238886
# Comma-separated E.164 allowlist. Leave blank to allow any (NOT recommended).
WHATSAPP_ALLOWED_NUMBERS=

# Signal via signal-cli-rest-api (https://github.com/bbernhard/signal-cli-rest-api)
# docker run -d -p 8080:8080 -e MODE=json-rpc bbernhard/signal-cli-rest-api
# Register your number at http://localhost:8080/v1/qrcodelink
# Set webhook URL to https://your-host/signal/webhook
SIGNAL_CLI_URL=http://localhost:8080
SIGNAL_PHONE_NUMBER=
# Comma-separated E.164 allowlist. Leave blank to allow any (NOT recommended).
SIGNAL_ALLOWED_NUMBERS=

# Ollama local models — run models entirely offline, no API key required.
# Install Ollama: https://ollama.com  →  then: ollama pull llama3.2
# Any model you pull is available with the ollama/ prefix (e.g. /model ollama/llama3.2)
# Default points at a local Ollama instance; change for a remote one.
OLLAMA_BASE_URL=http://localhost:11434/v1
# To add a local model to the council debate, set this (e.g. ollama/llama3.1):
OLLAMA_COUNCIL_MODEL=

# Cloud deployment (Railway / Render / any host)
# Set DASHBOARD_TOKEN to any strong password — empty = open (local dev)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_TOKEN=your_secret_token_here
DB_PATH=/data/apex.db

# IoT — Home Assistant integration (off by default)
# Set IOT_ENABLED=true to activate all three IoT layers (control, triggers, awareness).
# You can also toggle at runtime via the dashboard or: /iot on | /iot off
IOT_ENABLED=false
# Your Home Assistant base URL. LAN: http://homeassistant.local:8123
# Cloud: https://<your-id>.ui.nabu.casa  or via Tailscale subnet.
IOT_HA_URL=http://homeassistant.local:8123
# Long-lived access token from HA → Profile → Long-Lived Access Tokens
IOT_HA_TOKEN=
# HMAC-SHA256 secret for inbound webhook signature verification.
# Set the same value in your HA automation as the X-Apex-Signature header.
IOT_WEBHOOK_SECRET=
# Comma-separated entity_id allowlist for the passive awareness watcher.
# Example: binary_sensor.front_door,sensor.kitchen_temperature
# Leave blank to disable passive awareness (recommended until you know what you want).
IOT_AWARENESS_ENTITIES=
# Comma-separated entity_id allowlist for inbound trigger webhooks.
# Example: binary_sensor.driveway_motion,binary_sensor.front_door
# Leave blank to block all inbound triggers.
IOT_TRIGGER_ALLOWED_ENTITIES=
