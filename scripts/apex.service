[Unit]
Description=Apex AI Agent
Documentation=https://github.com/alexkhouryyy/ni
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%i
WorkingDirectory=/home/%i/ni
ExecStart=/home/%i/.local/bin/uv run python main.py --text
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1
StandardOutput=journal
StandardError=journal
SyslogIdentifier=apex

[Install]
WantedBy=multi-user.target
